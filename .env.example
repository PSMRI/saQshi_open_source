APP_ENV=local
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saqshi
DB_USERNAME=saqshi_user
DB_PASSWORD=change_me
DB_CONNECT_TIMEOUT=5

# Required for encrypting sensitive user profile fields such as name, email and mobile.
# Use a long random secret in each deployment and keep it stable after data is encrypted.
SAQSHI_FIELD_ENCRYPTION_KEY=change_this_to_a_long_random_secret

# Optional on Windows PHP if RSA key generation needs an OpenSSL config file.
OPENSSL_CONF=C:/php/extras/ssl/openssl.cnf

# Optional notification gateway secrets.
# Keep passwords/tokens in .env, not in JSON config or source code.
SAQSHI_MAIN_URL=https://example.org
SAQSHI_EMAIL_API_TOKEN=
SAQSHI_EMAIL_API_USERNAME=
SAQSHI_EMAIL_API_PASSWORD=
SAQSHI_EMAIL_API_KEY=
SAQSHI_SMS_API_TOKEN=
SAQSHI_SMS_API_USERNAME=
SAQSHI_SMS_API_PASSWORD=
SAQSHI_SMS_API_KEY=
